# --- LLM ---
LLM_PROVIDER=openai                # openai | anthropic
OPENAI_API_KEY=sk-replace-me       # required when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o                # model id

# --- Web search ---
TAVILY_API_KEY=tvly-replace-me     # required for Tavily-backed search tools

# --- Voice / SLNG ---
SLNG_API_KEY=slng-replace-me       # required for SLNG speech-to-text and text-to-speech

# --- WhatsApp integrations ---
WHATSAPP_MODE=stub                 # stub | cloud | twilio
WHATSAPP_GRAPH_API_VERSION=v25.0   # Meta Graph API version
WHATSAPP_ACCESS_TOKEN=replace-me   # required when WHATSAPP_MODE=cloud
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-me # WhatsApp Business Account ID
WHATSAPP_PHONE_NUMBER_ID=replace-me # sender phone number ID
WHATSAPP_VERIFY_TOKEN=replace-me   # random string also configured in Meta webhooks
WHATSAPP_APP_SECRET=               # Meta app secret; required in production cloud mode
TWILIO_ACCOUNT_SID=replace-me      # required when WHATSAPP_MODE=twilio
TWILIO_AUTH_TOKEN=replace-me       # required when WHATSAPP_MODE=twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 # Twilio Sandbox WhatsApp sender
TWILIO_VALIDATE_SIGNATURE=false    # validate X-Twilio-Signature on webhooks

# --- PostgreSQL ---
POSTGRES_HOST=postgres             # postgres service host inside Docker
POSTGRES_PORT=5432                 # postgres service port
POSTGRES_DB=chris                  # application database name
POSTGRES_USER=chris                # application database user
POSTGRES_PASSWORD=replace-me       # application database password

# --- App ---
APP_ENV=development                # development | staging | production
APP_LOG_LEVEL=info                 # debug | info | warning | error
APP_AGENT_TOOL_BUDGET=20           # max tool calls per turn
APP_AGENT_RUNTIME=deterministic    # deterministic | llm
